# ========================================
# ContentPulse - Environment Configuration
# ========================================
# Copy this file to .env.local in frontend and backend directories
# and fill in your actual values

# ========================================
# Frontend Environment Variables
# ========================================
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ========================================
# Backend Environment Variables
# ========================================
# App Configuration
APP_NAME=ContentPulse
APP_VERSION=0.1.0
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/contentpulse

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
API_V1_STR=/api/v1

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
